{
  "name": "procore-openlot",
  "version": "1.4.0",
  "description": "Procore OpenLot \u2014 lot management and conformance engine for civil construction, aligned to ATS 1120 Quality Management Requirements",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:demo": "cross-env DEMO_MODE=true tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/index.js",
    "start:demo": "cross-env DEMO_MODE=true node dist/src/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "exports:generate": "tsx scripts/generate-sample-exports.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.2",
    "fastify": "^5.1.0",
    "pg": "^8.13.1",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
