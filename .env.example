# ---- OpenLot configuration ------------------------------------------------
# Copy to .env and fill in. See docs/configuration.md for full detail.

NODE_ENV=production
PORT=4400
HOST=0.0.0.0

# Public URL of this OpenLot instance (used for OAuth redirect + webhooks).
# Must be HTTPS in production and reachable by Procore for webhooks.
APP_BASE_URL=https://openlot.example.com

# PostgreSQL connection string
DATABASE_URL=postgres://openlot:change-me@db:5432/openlot

# Run without Procore or Postgres using in-memory sample data (evaluation only)
DEMO_MODE=false

# ---- Procore OAuth app (Developer Portal > Create App) --------------------
PROCORE_CLIENT_ID=
PROCORE_CLIENT_SECRET=
PROCORE_BASE_URL=https://api.procore.com
PROCORE_LOGIN_URL=https://login.procore.com
# Web app host (not the API host) — only used to build "open in Procore"
# hyperlinks on the Reports dashboard. https://app.procore.com for US
# production; sandbox/EU/other data centers use a different host.
PROCORE_WEB_URL=https://app.procore.com
# Optional: pin the company when the OAuth user belongs to several
#PROCORE_COMPANY_ID=

# Shared secret OpenLot requires on inbound webhook deliveries
# (sent by Procore as the X-OpenLot-Webhook-Secret header).
# Generate with: openssl rand -hex 24
WEBHOOK_SHARED_SECRET=

# 64 hex chars (32 bytes) — AES-256-GCM key for OAuth tokens at rest.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
